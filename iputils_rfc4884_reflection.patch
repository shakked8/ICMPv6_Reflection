-/*
- * pinger --
- * 	Compose and transmit an ICMP ECHO REQUEST packet.  The IP packet
- * will be added on by the kernel.  The ID field is our UNIX process ID,
- * and the sequence number is an ascending integer.  The first several bytes
- * of the data portion are used to hold a UNIX "timeval" struct in VAX
- * byte-order, to compute the round-trip time.
- */
+/* RFC 4884 Checksum Calculation */
+static uint16_t calculate_checksum(void *b, int len)
+{
+    unsigned short *buf = b;
+    unsigned int sum = 0;
+    unsigned short result;
+
+    for (sum = 0; len > 1; len -= 2)
+        sum += *buf++;
+    if (len == 1)
+        sum += *(unsigned char *)buf;
+    sum = (sum >> 16) + (sum & 0xFFFF);
+    sum += (sum >> 16);
+    result = ~sum;
+    return result;
+}
+
 int build_echo(struct ping_rts *rts, uint8_t *_icmph,
-	       unsigned packet_size __attribute__((__unused__)))
+               unsigned packet_size __attribute__((__unused__)))
 {
-	struct icmp6_hdr *icmph;
-	int cc;
+    struct icmp6_hdr *icmph = (struct icmp6_hdr *)_icmph;
+    int cc;
 
-	icmph = (struct icmp6_hdr *)_icmph;
-	icmph->icmp6_type = ICMP6_ECHO_REQUEST;
-	icmph->icmp6_code = 0;
-	icmph->icmp6_cksum = 0;
-	icmph->icmp6_seq = htons(rts->ntransmitted + 1);
-	icmph->icmp6_id = rts->ident;
+    if (rts->opt_reflect) {
+        struct icmp_extension_header *ext_hdr;
+        struct reflect_object_header *obj_hdr;
+        uint8_t *payload_data;
+        int payload_len = 64;
+        int extension_total_len;
 
-	if (rts->timing)
-		gettimeofday((struct timeval *)&_icmph[8], NULL);
+        icmph->icmp6_type = ICMPV6_EXT_ECHO_REQUEST;
+        icmph->icmp6_code = 0;
+        icmph->icmp6_cksum = 0;
+        icmph->icmp6_seq = htons(rts->ntransmitted + 1);
+        icmph->icmp6_id = rts->ident;
 
-	cc = rts->datalen + 8;			/* skips ICMP portion */
+        ext_hdr = (struct icmp_extension_header *)(_icmph + 8);
+        obj_hdr = (struct reflect_object_header *)((uint8_t *)ext_hdr + sizeof(*ext_hdr));
+        payload_data = (uint8_t *)obj_hdr + sizeof(*obj_hdr);
 
-	return cc;
-}
+        ext_hdr->version_reserved = htons(2 << 12);
+        ext_hdr->checksum = 0;
+
+        obj_hdr->length = htons(4 + payload_len);
+        obj_hdr->class_num = CLASS_REFLECT_ALL;
+        obj_hdr->c_type = 0;
+
+        memset(payload_data, 0, payload_len);
+
+        extension_total_len = sizeof(*ext_hdr) + sizeof(*obj_hdr) + payload_len;
+        ext_hdr->checksum = calculate_checksum(ext_hdr, extension_total_len);
+
+        uint16_t seq = (rts->ntransmitted + 1) & 0xFFFF;
+        gettimeofday(&rts->reflect_send_times[seq], NULL);
 
+        cc = 8 + extension_total_len;
+        return cc;
+    }
 
+    /* Standard Echo Request */
+    icmph->icmp6_type = ICMP6_ECHO_REQUEST;
+    icmph->icmp6_code = 0;
+    icmph->icmp6_cksum = 0;
+    icmph->icmp6_seq = htons(rts->ntransmitted + 1);
+    icmph->icmp6_id = rts->ident;
+
+    if (rts->timing)
+        gettimeofday((struct timeval *)&_icmph[8], NULL);
+
+    cc = rts->datalen + 8;
+    return cc;
+}
