+
+static void print_formatted_hex(const uint8_t *data, size_t len, const char *indent) {
+    size_t i, j;
+    for (i = 0; i < len; i += 16) {
+        printf("%s0x%04zX:  ", indent, i);
+        for (j = 0; j < 16; j++) {
+            if (i + j < len)
+                printf("%02X ", data[i + j]);
+            else
+                printf("   ");
+        }
+        printf(" |");
+        for (j = 0; j < 16; j++) {
+            if (i + j < len) {
+                unsigned char c = data[i + j];
+                printf("%c", (c >= 32 && c <= 126) ? c : '.');
+            } else {
+                printf(" ");
+            }
+        }
+        printf("|\n");
+    }
+}
